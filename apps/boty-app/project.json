{
  "name": "boty-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/boty-app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/boty-app",
        "browser": "apps/boty-app/src/main.ts",
        "tsConfig": "apps/boty-app/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/boty-app/public"
          }
        ],
        "styles": ["apps/boty-app/src/styles.css"],
        "server": "apps/boty-app/src/main.server.ts",
        "prerender": true,
        "outputMode": "static"
      },
      "configurations": {
        "production": {
          "optimization": {
            "scripts": true,
            "styles": true,
            "fonts": false
          },
          "outputHashing": "all",
          "budgets": [
            { "type": "initial", "maximumWarning": "2mb", "maximumError": "5mb" },
            { "type": "anyComponentStyle", "maximumWarning": "16kb", "maximumError": "64kb" }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "boty-app:build:production"
        },
        "development": {
          "buildTarget": "boty-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "boty-app:build",
        "port": 4200,
        "staticFilePath": "dist/apps/boty-app/browser",
        "spa": true
      }
    }
  }
}
